# ── M-Pesa (Safaricom Daraja) STK Push ──────────────────────────────────────
# When ALL of the required keys below are present, real STK Push is used.
# When any are missing, payments fall back to SIMULATION mode (auto-confirmed),
# so the app works out of the box for development without credentials.

# Required for live payments:
MPESA_CONSUMER_KEY=5CzKoC7Vyp4jAOFdBSN2asMeEteYAzLxT2jAjrkBFAaD2TmA
MPESA_CONSUMER_SECRET=YwWusz2gUqrLphj0zIUAmfoMsSywjcVFRAXw0hQAFP1EannsJO3srilAjGufiQKt
MPESA_SHORTCODE=3470771
MPESA_STORE_NUMBER=4647813
MPESA_PASSKEY=ae839b8b7f4fb39c49f2a45f5d7e876975f0b5c4019349e0cea7190a91b1c53c

# Optional:
# "sandbox" (default) or "production"
MPESA_ENV=production
# Public callback URL Safaricom posts results to. If omitted, it is derived
# automatically from REPLIT_DOMAINS as https://<domain>/api/payments/callback
# MPESA_CALLBACK_URL=https://32c3ad915f0496.lhr.life/api/payments/callback
# Timeout and Result callback URLs for B2B/B2C payouts.
MPESA_CALLBACK_TIMEOUT_URL=
MPESA_CALLBACK_RESULT_URL=
# Platform delivery fee
DELIVERY_FEE=60

# Email Notification System
YAJJA_EMAIL=yajjaapp@gmail.com
YAJJA_EMAIL_PASSWORD=atjw xlye nmwc cgry

# Required for live payouts/disbursements (B2B/B2C):
# If these are missing, vendor payouts fall back to simulation mode.
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=

# STK Push transaction type: "CustomerPayBillOnline" (default) or "CustomerBuyGoodsOnline"
MPESA_TRANSACTION_TYPE=CustomerBuyGoodsOnline

