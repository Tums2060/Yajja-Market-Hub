# ── M-Pesa (Safaricom Daraja) STK Push ──────────────────────────────────────
# When ALL of the required keys below are present, real STK Push is used.
# When any are missing, payments fall back to SIMULATION mode (auto-confirmed),
# so the app works out of the box for development without credentials.

# Required for live payments:
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=

# Optional:
# "sandbox" (default) or "production"
MPESA_ENV=sandbox
# Public callback URL Safaricom posts results to. If omitted, it is derived
# automatically from REPLIT_DOMAINS as https://<domain>/api/payments/callback
MPESA_CALLBACK_URL=
# Platform commission as a fraction of the order subtotal (default 0.15 = 15%)
MPESA_COMMISSION_RATE=0.15

# ── Database dialect ────────────────────────────────────────────────────────
# "postgres" (default, what Replit provisions) or "mysql" / "mariadb".
DB_DIALECT=postgres

# Postgres uses DATABASE_URL (already set by Replit).
# For MySQL/MariaDB, either set a mysql:// DATABASE_URL, e.g.
#   DATABASE_URL=mysql://user:pass@127.0.0.1:3306/yajja
# or provide the discrete connection parts below:
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=yajja
DB_USER=root
DB_PASSWORD=

# Set to 1 to log every SQL query (both dialects).
DB_LOG_QUERIES=
