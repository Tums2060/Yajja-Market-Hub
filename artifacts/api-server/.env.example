# ── M-Pesa (Safaricom Daraja) STK Push & Payouts ──────────────────────────────
# When ALL of the required keys below are present, real STK Push is used.
# When any are missing, payments fall back to SIMULATION mode (auto-confirmed),
# so the app works out of the box for development without credentials.

# Required for live payments:
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_STORE_NUMBER=
MPESA_PASSKEY=

# Required for live payouts/disbursements (B2B/B2C):
# If these are missing, vendor payouts fall back to simulation mode.
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=

# Optional:
# "sandbox" (default) or "production"
MPESA_ENV=sandbox
# Override base URL for Daraja API endpoints (e.g. for reverse proxy or direct override)
MPESA_BASE_URL=
# STK Push transaction type: "CustomerPayBillOnline" (default) or "CustomerBuyGoodsOnline"
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
# Public callback URL Safaricom posts STK Push results to.
MPESA_CALLBACK_URL=
# Timeout and Result callback URLs for B2B/B2C payouts.
MPESA_CALLBACK_TIMEOUT_URL=
MPESA_CALLBACK_RESULT_URL=
# Platform delivery fee
DELIVERY_FEE=60

# Email Notification System
YAJJA_EMAIL=
YAJJA_EMAIL_PASSWORD=

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# On Replit, DATABASE_URL is provisioned automatically. For local development,
# point it at your local Postgres instance, e.g.:
#   DATABASE_URL=postgresql://localhost:5432/yajja_market
# or with credentials:
#   DATABASE_URL=postgresql://tumaini:tumaini@localhost:5432/yajja_market
DATABASE_URL=

# Set to 1 to log every SQL query.
DB_LOG_QUERIES=
